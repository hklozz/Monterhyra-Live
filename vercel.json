{
  "git": {
    "deploymentEnabled": {
      "main": true
    }
  },
  "framework": "vite",
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "installCommand": "npm install",
  "redirects": [
    {
      "source": "/:path*",
      "has": [{ "type": "host", "value": "www.monterhyra.com" }],
      "destination": "https://monterhyra.com/:path*",
      "permanent": true
    }
  ]
}
